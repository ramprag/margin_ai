# Margin AI Environment Configuration

# Provider Keys (at least one is required)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Infrastructure
REDIS_URL=redis://localhost:6379/0
# Production (Docker Compose): PostgreSQL
DATABASE_URL=postgresql://marginai:marginai@localhost:5432/marginai
# Lightweight Dev Mode (no Docker needed): SQLite
# DATABASE_URL=sqlite:///./margin_ai.db

# Gateway Authentication
# Comma-separated list of valid API keys. Leave empty for open gateway mode (local dev).
MARGIN_API_KEYS=

# Routing & Caching Settings
PII_REDACTION_ENABLED=True
PROMPT_INJECTION_CHECK_ENABLED=True
COST_THRESHOLD=0.5
SIMILARITY_THRESHOLD=0.95
